  "_instructions": [
    "Only capture founders, C-suite, board members, and key advisors. Do not collect below VP level.",
    "BEFORE ADDING A NEW RECORD: search for linkedin_url and full_name.",
    "linkedin_url is the primary deduplication anchor \u2014 more stable than job title or company name.",
    "Only store nationality, clearance, and intelligence background if voluntarily and publicly disclosed.",
    "Never infer sensitive fields from circumstantial signals.",
    "Set review_after to 6 months \u2014 shorter than any other entity type. Roles change fast.",
    "IDs use prefix 'per-' e.g. per-gundbert-scherf."
  ],
  "_deduplication_rules": {
    "primary_anchor": "linkedin_url",
    "secondary_anchor": "full_name + current_company_ref",
    "agent_instruction": "Before inserting a new person, check linkedin_url against all existing records. If unknown, check full_name against all records."
  },
  "_computed_live_from_events": [
    "previous_companies \u2014 derived from key_hire and key_departure events",
    "serial_founder \u2014 derived from career history events",
    "prior_exit \u2014 derived from acquisition or ipo events involving previous companies"
  ],
