{
  "_template_version": "2.0",
  "_description": "European Defence Tech Knowledge Graph — Funding Rounds (master records)",
  "_layer": "master",
  "_instructions": [
    "This file is ONLY written to by the confirmation agent — never by scraping agents.",
    "A round is promoted here only when confidence_score >= 0.75 AND a primary source URL exists.",
    "All numeric fields carry _min, _max, _best suffix to express uncertainty ranges.",
    "Use null for unknown values — never use 0 for unknown amounts.",
    "Always store amount_original and currency_original alongside amount_eur fields.",
    "investor_list_complete must be set explicitly — default to false if unsure.",
    "IDs use prefix 'rd-' e.g. rd-helsing-series-d-2025."
  ],

  "_deduplication_rules": {
    "primary_anchor": "company_ref + announced_date — same company same date = same round",
    "secondary_anchor": "company_ref + round_type + approximate amount",
    "agent_instruction": "Before promoting a round, check whether any existing record has the same company_ref and announced_date. If so, update that record."
  },

  "_promotion_threshold": {
    "minimum_confidence_score": 0.75,
    "requires_primary_source": true,
    "rationale": "Funding data is inherently opaque. Below 0.75 confidence, rounds remain in the event stream only."
  },

  "_computed_live_from_events": [
    "total_raised_eur per company — sum of all promoted rounds for that company"
  ],

  "template": {
    "round_id": "rd-COMPANY-SLUG-round-type-YYYY",
    "company_ref": "co-SLUG",
    "round_type": "ONE OF: pre_seed | seed | series_a | series_b | series_c | series_d | growth | grant | contract | convertible | secondary",
    "announced_date": "YYYY-MM-DD",
    "closed_date": null,

    "money": {
      "amount_eur_min": null,
      "amount_eur_max": null,
      "amount_eur_best": null,
      "amount_original_min": null,
      "amount_original_max": null,
      "amount_original_best": null,
      "currency_original": "EUR",
      "amount_disclosed": null,
      "post_money_valuation_eur_min": null,
      "post_money_valuation_eur_max": null,
      "post_money_valuation_eur_best": null
    },

    "participants": {
      "lead_investor_refs": [],
      "participating_investor_refs": [],
      "investor_list_complete": false,
      "new_vs_follow_on": {}
    },

    "defence_specific": {
      "round_includes_grant": null,
      "grant_ref": null,
      "nato_aligned": null,
      "foreign_capital_flag": null,
      "foreign_capital_note": null,
      "use_of_proceeds": null
    },

    "record_status": "ONE OF: bootstrap | agent_enriched | confirmed",
    "sourced_from_event_ids": [],

    "provenance": {
      "primary_source_url": "https://",
      "secondary_source_urls": [],
      "confidence_score": null,
      "confidence_rationale": null,
      "added_by": "ONE OF: human/manual | agent/confirmation",
      "asserted_on": "YYYY-MM-DD",
      "review_after": "YYYY-MM-DD"
    }
  },

