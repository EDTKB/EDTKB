{
  "_template_version": "1.1",
  "_description": "European Defence Tech Knowledge Graph — Funding Rounds",
  "_instructions": [
    "Copy the object inside 'template' for each new funding round.",
    "BEFORE ADDING A NEW RECORD: search for the company_ref + round_type + announced_date combination.",
    "A duplicate is any record with the same company and the same announced date — not just the same round_type.",
    "IDs use prefix 'rd-' e.g. rd-helsing-series-d-2025.",
    "Always store amount_original alongside amount_eur — never discard the source currency.",
    "Use null for undisclosed amounts — never use 0."
  ],

  "_deduplication_rules": {
    "primary_anchor": "company_ref + announced_date — same company, same date = same round",
    "secondary_anchor": "company_ref + round_type + approximate amount",
    "agent_instruction": "Before inserting a new round, check whether any existing record has the same company_ref and announced_date. If so, update that record rather than creating a new one."
  },

  "_round_type_enum": ["pre_seed", "seed", "series_a", "series_b", "series_c", "series_d", "growth", "grant", "contract", "convertible", "secondary"],
  "_funding_instrument_enum": ["grant", "loan", "equity", "contract", "blended"],
  "_ip_retention_enum": ["full", "shared", "government_licence", "classified"],

