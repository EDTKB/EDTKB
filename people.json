{
  "_template_version": "1.1",
  "_description": "European Defence Tech Knowledge Graph — People",
  "_instructions": [
    "Only capture founders, C-suite, board members, and key advisors. Do not collect below VP level.",
    "BEFORE ADDING A NEW RECORD: search for the linkedin_url and full_name.",
    "linkedin_url is the primary deduplication anchor — it is more stable than job title or company.",
    "IDs use prefix 'per-' e.g. per-gundbert-scherf.",
    "Only store nationality, clearance, and intelligence background if voluntarily and publicly disclosed.",
    "Never infer sensitive fields from circumstantial signals."
  ],

  "_deduplication_rules": {
    "primary_anchor": "linkedin_url — most stable unique identifier for a person",
    "secondary_anchor": "full_name + current_company_ref combination",
    "agent_instruction": "Before inserting a new person, check whether the linkedin_url already exists in any record. If so, update that record. If linkedin_url is unknown, check full_name against all existing records."
  },

  "_role_type_enum": ["founder", "co_founder", "ceo", "cto", "coo", "cfo", "vp", "board", "advisor", "investor"],
  "_domain_expertise_enum": ["autonomous_systems", "signals_intelligence", "cyber", "procurement", "battlefield_ai", "logistics", "space", "maritime", "electronic_warfare", "propulsion", "simulation"],

  "template": {
    "person_id": "per-FIRSTNAME-LASTNAME",
    "full_name": "First Last",
    "linkedin_url": "https://linkedin.com/in/SLUG",
    "nationality": null,

    "current_role": {
      "company_ref": "co-SLUG",
      "title": "Job Title",
      "role_type": "ONE FROM ROLE TYPE ENUM ABOVE",
      "role_start_date": "YYYY-MM"
    },

    "career_history": [
      {
        "organisation": "Organisation Name",
        "organisation_ref": null,
        "title": "Job Title",
        "from": "YYYY",
        "until": "YYYY"
      }
    ],

    "defence_background": {
      "military_background": null,
      "military_detail": null,
      "government_background": null,
      "government_detail": null,
      "intelligence_background": null,
      "security_clearance_country": null,
      "domain_expertise": []
    },

    "network": {
      "advisor_to": [],
      "board_seats": []
    },

    "provenance": {
      "primary_source_url": "https://",
      "confidence": "ONE OF: confirmed | corroborated | inferred | rumoured",
      "added_by": "ONE OF: human/manual | agent/web-enrichment | agent/news-scraper",
      "asserted_on": "YYYY-MM-DD",
      "review_after": "YYYY-MM-DD"
    }
  },

