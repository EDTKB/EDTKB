{
  "_template_version": "2.0",
  "_description": "European Defence Tech Knowledge Graph — Programmes (master records)",
  "_layer": "master",
  "_instructions": [
    "Covers grant programmes, accelerators, procurement frameworks, and bilateral R&D treaties.",
    "BEFORE ADDING A NEW RECORD: search for short_name and canonical_domain.",
    "Programmes are slow-moving — review_after can be set to 6–12 months except for current_call_deadline.",
    "current_call_deadline has its own review_after of 30 days — set this separately in a note.",
    "Always distinguish funding_instrument: grant vs contract vs equity — different obligations.",
    "IDs use prefix 'prog-' e.g. prog-nato-diana."
  ],

  "_deduplication_rules": {
    "primary_anchor": "canonical_domain",
    "secondary_anchor": "short_name — acronyms are widely unique in this space",
    "agent_instruction": "Before inserting a new programme, check short_name and canonical_domain against all existing records."
  },

  "_computed_live_from_events": [
    "participant_companies — derived from programme_entry events",
    "participant_count — count of distinct companies in programme_entry events",
    "notable_alumni — companies that raised significant rounds after programme_entry event"
  ],

